{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "hm13101998adf"
		},
		"ADLS_Customer_json_Linkedservice_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_Customer_json_Linkedservice'"
		},
		"ADLS_LinkedService_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_LinkedService'"
		},
		"SQL_DB_Customer_Linked_Service_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SQL_DB_Customer_Linked_Service'"
		},
		"SQL_DB_LinkedService_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SQL_DB_LinkedService'"
		},
		"adls_product_Linkedservice_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adls_product_Linkedservice'"
		},
		"sqldb_product_LinkedService_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'sqldb_product_LinkedService'"
		},
		"ADLS_Customer_json_Linkedservice_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://hm13101998adls.dfs.core.windows.net/"
		},
		"ADLS_LinkedService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://hm13101998adls.dfs.core.windows.net/"
		},
		"SQL_DB_Customer_Linked_Service_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mission100server.database.windows.net"
		},
		"SQL_DB_Customer_Linked_Service_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hm13101998db"
		},
		"SQL_DB_Customer_Linked_Service_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure"
		},
		"SQL_DB_LinkedService_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mission100server.database.windows.net"
		},
		"SQL_DB_LinkedService_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hm13101998db"
		},
		"SQL_DB_LinkedService_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure"
		},
		"adls_product_Linkedservice_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://hm13101998adls.dfs.core.windows.net/"
		},
		"sqldb_product_LinkedService_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "mission100server.database.windows.net"
		},
		"sqldb_product_LinkedService_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hm13101998db"
		},
		"sqldb_product_LinkedService_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ADLS_Customer_json_Linkedservice')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ADLS_Customer_json_Linkedservice_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ADLS_Customer_json_Linkedservice_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ADLS_LinkedService')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ADLS_LinkedService_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ADLS_LinkedService_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/SQL_DB_Customer_Linked_Service')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('SQL_DB_Customer_Linked_Service_properties_typeProperties_server')]",
					"database": "[parameters('SQL_DB_Customer_Linked_Service_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('SQL_DB_Customer_Linked_Service_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('SQL_DB_Customer_Linked_Service_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/SQL_DB_LinkedService')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('SQL_DB_LinkedService_properties_typeProperties_server')]",
					"database": "[parameters('SQL_DB_LinkedService_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('SQL_DB_LinkedService_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('SQL_DB_LinkedService_password')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/adls_product_Linkedservice')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('adls_product_Linkedservice_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('adls_product_Linkedservice_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/sqldb_product_LinkedService')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('sqldb_product_LinkedService_properties_typeProperties_server')]",
					"database": "[parameters('sqldb_product_LinkedService_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('sqldb_product_LinkedService_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('sqldb_product_LinkedService_password')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}